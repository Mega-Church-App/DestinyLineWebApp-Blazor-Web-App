@page "/"
@rendermode InteractiveWebAssembly
@using DestinyLineWebApp.Client.Models
@using DestinyLineWebApp.Client.Services

@inject IMemberService MemberService

<PageTitle>Service Attendance</PageTitle>

<nav class="attendance-nav">
    <h1>Service Attendance (@(Attendees?.Count ?? 0))</h1>
</nav>

<main class="attendance-mdiv">
    <div class="toast @(IsToastVisible ? "show" : "") @(ToastClass)">
        @((MarkupString)ToastMessage)
    </div>

    <section class="form-section attendance-form-group">
        <EditForm Model="@CurrentAttendee" OnValidSubmit="HandleSubmit" FormName="attendanceForm">
            <div class="attendance-form-div">
                <div>
                    <label>
                        FullName:
                        <InputText @bind-Value="CurrentAttendee.FullName" class="form-control" placeholder="Daniel David" required />
                    </label>
                </div>

                <div>
                    <label>
                        Phone Number:
                        <InputText @bind-Value="CurrentAttendee.Phone" class="form-control" placeholder="0123456789" required />
                    </label>
                </div>

                <div>
                    <label>
                        Location:
                        <InputText @bind-Value="CurrentAttendee.Location" class="form-control" placeholder="Lapaz" required />
                    </label>
                </div>

                <div class="button-container">
                    <button class="attendance-submit-btn" type="submit">
                        SAVE INPUT
                    </button>
                </div>
            </div>
        </EditForm>
    </section>

    <section class="list-section">
        <table class="table attendance-table">
            <thead>
                <tr class="attendance-tr">
                    <th class="attendance-th">Full Name</th>
                    <th class="attendance-th">Phone Number</th>
                    <th class="attendance-th">Location</th>
                </tr>
            </thead>
            <tbody>
                @if (Attendees != null)
                {
                    @foreach (var entry in Attendees)
                    {
                        <tr class="@(entry.IsFirstTimer ? "first-timer-row" : "")">
                            <td class="attendance-td" ;"><strong>@entry.FullName</strong></td>
                            <td class="attendance-td" ;">@entry.Phone</td>
                            <td class="attendance-td" ;">@entry.Location</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>
</main>

@code {
    private Attendee CurrentAttendee = new Attendee();
    private List<Attendee> Attendees = new List<Attendee>();
    
    // Toast Variables
    private bool IsToastVisible = false;
    private string ToastMessage = "";
    private string ToastClass = "";

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to live updates if your service supports it,
        // or fetch current attendance list
        await LoadAttendees();
    }

    private async Task LoadAttendees()
    {
        Attendees = await MemberService.GetAttendanceList();
    }

    private async Task HandleSubmit()
    {
        // 1. Check for Duplicates (Logic from your JS)
        if (Attendees.Any(a => a.Phone == CurrentAttendee.Phone))
        {
            ShowToast("This phone number has already checked in!", "error");
            return;
        }

        bool existsAsMember = await MemberService.CheckIfMemberExists(CurrentAttendee.Phone);
        
        CurrentAttendee.Timestamp = DateTime.Now;
        
        if (existsAsMember)
        {
            CurrentAttendee.IsFirstTimer = false;
            await MemberService.SaveAttendance(CurrentAttendee);
            ShowToast($"Welcome to <span>DestinyLine</span>, {CurrentAttendee.FullName}🎉!");
        }
        else
        {
            CurrentAttendee.IsFirstTimer = true;
            await MemberService.SaveAttendance(CurrentAttendee);
            // In your JS logic, first timers are also marked as members
            await MemberService.MarkAsMember(CurrentAttendee.Phone);
            ShowToast($"🥳🙌🎉Welcome to <span>DestinyLine</span>, {CurrentAttendee.FullName}🥳🙌🎉!", "flashy");
        }

        // 3. Reset and Refresh
        CurrentAttendee = new Attendee();
        await LoadAttendees();
    }

    private void ShowToast(string message, string cssClass = "")
    {
        ToastMessage = message;
        ToastClass = cssClass;
        IsToastVisible = true;
        
        // Hide toast after 3 seconds
        Task.Delay(3000).ContinueWith(_ =>
        {
            IsToastVisible = false;
            InvokeAsync(StateHasChanged);
        });
    }
}